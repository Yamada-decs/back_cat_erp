<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>Cotización</title>
  <style>
    body {
      font-family: 'Helvetica', 'Arial', sans-serif;
      font-size: 14px;
      color: #333;
      margin: 0;
      padding: 0;
    }
    .header {
      width: 100%;
      border-bottom: 3px solid #FFCD11;
      padding-bottom: 20px;
      margin-bottom: 30px;
    }
    .logo {
      font-size: 28px;
      font-weight: bold;
      color: #1B1B1B;
    }
    .logo span {
      color: #FFCD11;
    }
    .company-details {
      float: right;
      text-align: right;
      font-size: 12px;
      color: #666;
    }
    .title-area {
      margin-bottom: 30px;
    }
    .title-area h1 {
      margin: 0 0 10px 0;
      color: #1B1B1B;
      text-transform: uppercase;
      font-size: 24px;
    }
    .info-table {
      width: 100%;
      margin-bottom: 30px;
    }
    .info-table td {
      vertical-align: top;
      width: 50%;
    }
    .info-box {
      background: #f9f9f9;
      padding: 15px;
      border-radius: 5px;
      border: 1px solid #eee;
    }
    .info-box strong {
      display: block;
      margin-bottom: 5px;
      color: #1B1B1B;
    }
    table.items {
      width: 100%;
      border-collapse: collapse;
      margin-bottom: 30px;
    }
    table.items th {
      background: #1B1B1B;
      color: #FFCD11;
      padding: 10px;
      text-align: left;
      font-size: 12px;
      text-transform: uppercase;
    }
    table.items td {
      padding: 10px;
      border-bottom: 1px solid #eee;
    }
    table.items td.right, table.items th.right {
      text-align: right;
    }
    .totals {
      width: 40%;
      float: right;
      background: #f9f9f9;
      padding: 15px;
      border-radius: 5px;
      border: 1px solid #eee;
    }
    .totals table {
      width: 100%;
    }
    .totals td {
      padding: 5px 0;
    }
    .totals td.right {
      text-align: right;
    }
    .totals .grand-total {
      font-size: 18px;
      font-weight: bold;
      color: #1B1B1B;
      border-top: 2px solid #ddd;
      padding-top: 10px;
      margin-top: 5px;
    }
    .footer {
      position: fixed;
      bottom: 0;
      left: 0;
      width: 100%;
      text-align: center;
      font-size: 10px;
      color: #999;
      border-top: 1px solid #eee;
      padding-top: 10px;
    }
    .clear {
      clear: both;
    }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
